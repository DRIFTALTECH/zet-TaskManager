# ZET frontend — environment template. Copy to frontend/.env and fill real values.

# Backend API base URL (scheme + host + port, no trailing path)
VITE_API_URL=http://localhost:8000

# Microsoft sign-in (buttons appear only when client id is set). Same values as backend.
VITE_MICROSOFT_CLIENT_ID=
VITE_MICROSOFT_TENANT_ID=          # optional; defaults to "common" (multi-tenant)

# MCP endpoint shown in Settings → Developer settings. Defaults to <VITE_API_URL>/mcp.
# VITE_MCP_URL=http://localhost:8000/mcp
