# ZET backend — environment template. Copy to backend/.env and fill real values.
# In production (APP_ENV=production) the app FAILS TO START if the secrets marked
# "required in prod" are missing or left at dev defaults.

# ── Microsoft (sign-in + Teams transcripts) ─────────────────────────────────
MICROSOFT_CLIENT_ID=            # Entra app (client) ID; same as VITE_MICROSOFT_CLIENT_ID
MICROSOFT_TENANT_ID=            # Directory (tenant) ID; real id, NOT "common"
MICROSOFT_CLIENT_SECRET=        # client secret — ONLY needed for Teams → MOM import

# ── AI: Groq (primary) ──────────────────────────────────────────────────────
GROQ_API_KEY=                   # required for any AI feature (chat, parse, transcribe)
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_AGENT_MODEL=llama-3.3-70b-versatile
GROQ_STRICT_MODEL=llama-3.3-70b-versatile
GROQ_WHISPER_MODEL=whisper-large-v3-turbo   # speech-to-text for scrum audio

# ── AI: Ollama (automatic fallback) ─────────────────────────────────────────
AI_OLLAMA_FALLBACK=1
OLLAMA_BASE_URL=https://ollama.com          # or http://localhost:11434 for local
OLLAMA_MODEL=gpt-oss:120b
OLLAMA_API_KEY=                 # only for Ollama Cloud (ollama.com)
# AI_REQUEST_TIMEOUT=45
# AI_MAX_RETRIES=2

# ── Auth / admin (required in prod) ─────────────────────────────────────────
APP_ENV=development             # set "production" to enforce the checks
TASKMANAGER_JWT_SECRET=         # >=32 chars in prod
ADMIN_USERNAME=admin
ADMIN_PASSWORD=                 # >=8 chars in prod (dev default: Default@123)
CORS_ORIGINS=                   # comma-separated origins; required in prod

# ── URLs / database ─────────────────────────────────────────────────────────
ZET_PUBLIC_URL=http://localhost:8000        # real https origin in prod (OAuth/MCP metadata)
# DATABASE_URL=postgresql+psycopg://user:pass@host:5432/zet   # default: local SQLite
# TASKMANAGER_SQLITE_PATH=./data/taskmanager.db

# ── Ops (optional) ──────────────────────────────────────────────────────────
# LOG_LEVEL=INFO
# SENTRY_DSN=
# SENTRY_TRACES_RATE=0.1
# REDIS_URL=redis://localhost:6379/0          # cross-worker realtime fan-out
